{
  "name": "vtk-pointcloud-lod",
  "version": "0.0.1",
  "description": "Octree LOD point-cloud streaming for vtk.js",
  "type": "module",
  "license": "BSD-3-Clause",
  "sideEffects": false,
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
