{
  "name": "pointcloud-lod",
  "version": "0.0.1",
  "description": "Octree LOD point-cloud streaming for vtk.js",
  "type": "module",
  "license": "MIT",
  "author": "Paul Elliott",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PaulHax/pointcloud-lod.git"
  },
  "homepage": "https://github.com/PaulHax/pointcloud-lod#readme",
  "bugs": {
    "url": "https://github.com/PaulHax/pointcloud-lod/issues"
  },
  "keywords": [
    "vtk",
    "vtk.js",
    "point-cloud",
    "lod",
    "octree",
    "copc",
    "streaming",
    "webgl"
  ],
  "sideEffects": false,
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "vite build && tsc -p tsconfig.build.json",
    "prepare": "npm run build"
  },
  "peerDependencies": {
    "@kitware/vtk.js": ">=36"
  },
  "dependencies": {
    "copc": "^0.0.8"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "peerDependenciesMeta": {
    "@kitware/vtk.js": {
      "optional": true
    }
  }
}
