  },
  "peerDependencies": {
    "@kitware/vtk.js": ">=36"
  },
  "dependencies": {
    "copc": "^0.0.8"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
